y="2370"><span data-slate-object="text" data-key="2371"><span data-slate-leaf="true" data-offset-key="2371:0" data-first-offset="true"><span data-slate-string="true">OpenClaw，</span></span></span><a data-slate-type="link" data-slate-object="inline" data-key="2372" class="se-f828cddd se-8ab6c248"><span data-slate-object="text" data-key="2373"><span data-slate-leaf="true" data-offset-key="2373:0" data-first-offset="true"><span data-slate-string="true">openclaw/openclaw GitHub repository</span></span></span></a></div><div class="se-dfd97de6 se-409bed2d" data-slate-type="list-line" data-slate-object="block" data-key="2374"><span data-slate-object="text" data-key="2375"><span data-slate-leaf="true" data-offset-key="2375:0" data-first-offset="true"><span data-slate-string="true">Nous Research，</span></span></span><a data-slate-type="link" data-slate-object="inline" data-key="2376" class="se-f828cddd se-8ab6c248"><span data-slate-object="text" data-key="2377"><span data-slate-leaf="true" data-offset-key="2377:0" data-first-offset="true"><span data-slate-string="true">hermes-agent GitHub repository</span></span></span></a></div><div class="se-778d21c4 se-7f3a6b5a" data-slate-type="list-line" data-slate-object="block" data-key="2378"><span data-slate-object="text" data-key="2379"><span data-slate-leaf="true" data-offset-key="2379:0" data-first-offset="true"><span data-slate-string="true">ByteDance，</span></span></span><a data-slate-type="link" data-slate-object="inline" data-key="2380" class="se-f828cddd se-8ab6c248"><span data-slate-object="text" data-key="2381"><span data-slate-leaf="true" data-offset-key="2381:0" data-first-offset="true"><span data-slate-string="true">deer-flow GitHub repository</span></span></span></a></div><div class="se-f87a7a92 se-dd0654c0" data-slate-type="list-line" data-slate-object="block" data-key="2382"><span data-slate-object="text" data-key="2383"><span data-slate-leaf="true" data-offset-key="2383:0" data-first-offset="true"><span data-slate-string="true">OpenHands，</span></span></span><a data-slate-type="link" data-slate-object="inline" data-key="2384" class="se-f828cddd se-8ab6c248"><span data-slate-object="text" data-key="2385"><span data-slate-leaf="true" data-offset-key="2385:0" data-first-offset="true"><span data-slate-string="true">Events docs</span></span></span></a></div><div class="se-8e7d432e se-5dff91ee" data-slate-type="list-line" data-slate-object="block" data-key="2386"><span data-slate-object="text" data-key="2387"><span data-slate-leaf="true" data-offset-key="2387:0" data-first-offset="true"><span data-slate-string="true">OpenHands，</span></span></span><a data-slate-type="link" data-slate-object="inline" data-key="2388" class="se-f828cddd se-8ab6c248"><span data-slate-object="text" data-key="2389"><span data-slate-leaf="true" data-offset-key="2389:0" data-first-offset="true"><span data-slate-string="true">Sandbox overview</span></span></span></a></div><div class="se-f16a489c se-78907627" data-slate-type="list-line" data-slate-object="block" data-key="2390"><span data-slate-object="text" data-key="2391"><span data-slate-leaf="true" data-offset-key="2391:0" data-first-offset="true"><span data-slate-string="true">OpenHands，</span></span></span><a data-slate-type="link" data-slate-object="inline" data-key="2392" class="se-f828cddd se-8ab6c248"><span data-slate-object="text" data-key="2393"><span data-slate-leaf="true" data-offset-key="2393:0" data-first-offset="true"><span data-slate-string="true">OpenHands paper</span></span></span></a></div></div></div>